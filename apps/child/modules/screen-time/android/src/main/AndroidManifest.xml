<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
  <application>
    <service
      android:name="expo.modules.screentime.AppBlockerService"
      android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
      android:exported="false"
      android:label="KidsGuard Contrôle parental">
      <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
      </intent-filter>
      <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/kidsguard_accessibility" />
    </service>

    <receiver
      android:name="expo.modules.screentime.KidsGuardAdminReceiver"
      android:permission="android.permission.BIND_DEVICE_ADMIN"
      android:exported="true">
      <meta-data
        android:name="android.app.device_admin"
        android:resource="@xml/kidsguard_device_admin" />
      <intent-filter>
        <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
